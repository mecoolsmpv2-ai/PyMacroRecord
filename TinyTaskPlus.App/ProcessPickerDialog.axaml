<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:TinyTaskPlus.Core;assembly=TinyTaskPlus.Core"
        x:Class="TinyTaskPlus.App.ProcessPickerDialog"
        Title="Select Application" Width="720" Height="480">
	<Grid RowDefinitions="Auto,*,Auto" Margin="12">
		<TextBox x:Name="FilterBox" Watermark="Filter by title/name..."/>
		<ListBox x:Name="ProcessList" Grid.Row="1" SelectionMode="Single">
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="core:ProcessInfo">
					<StackPanel Spacing="2">
						<TextBlock Text="{Binding MainWindowTitle}" FontWeight="Bold"/>
						<TextBlock Text="{Binding ProcessName}"/>
						<TextBlock Text="{Binding FileName}" FontSize="11" Opacity="0.7"/>
					</StackPanel>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
		<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
			<Button x:Name="RefreshButton" Content="Refresh"/>
			<Button x:Name="CancelButton" Content="Cancel"/>
			<Button x:Name="OkButton" Content="OK"/>
		</StackPanel>
	</Grid>
</Window>